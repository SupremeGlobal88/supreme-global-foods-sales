# Database (your existing MySQL database)
DATABASE_URL=mysql://username:password@host:port/database

# App credentials (from your Kimi portal)
APP_ID=your-app-id
APP_SECRET=your-app-secret
KIMI_AUTH_URL=https://your-auth-url
KIMI_OPEN_URL=https://your-open-url
OWNER_UNION_ID=your-owner-id

# Production
NODE_ENV=production
PORT=3000
